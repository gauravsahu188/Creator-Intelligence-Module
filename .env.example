# ============================================================
# Creator Intelligence Module — Environment Variables Example
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ============================================================

# ScrapOps Residential Proxy (for Instagram profile scraping)
# Get your key at: https://scrapeops.io
SCRAPEOPS_API_KEY=your_scrapeops_api_key_here

# PostgreSQL Database Connection (Unified URI OR Individual fields)
# Use DATABASE_URL for hosted databases like Supabase or Neon.
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=your_supabase_postgresql_connection_url_here

# Alternatively, set individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=instagram_scrapper_data
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Apify — Instagram Comment Scraper
# Get your token at: https://apify.com
APIFY_API_TOKEN=your_apify_api_token_here

# Google Gemini AI (2.5 Flash)
# Get your key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
